# Flask Configuration
FLASK_APP=main.py
FLASK_ENV=development
FLASK_DEBUG=True

# Database Configuration
DATABASE_URL=sqlite:///students.db
SQL_ECHO=False

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=900

# API Configuration
API_PORT=5000
API_HOST=127.0.0.1

# Security
CORS_ORIGINS=http://localhost:3000
